---
import Hero from '@/components/Hero.astro';
import Layout from '../layouts/Layout.astro';
import Services from '@/components/home/Services.astro';
import Team from '@/components/home/Team.astro';
import Faq from '@/components/home/Faq.astro';
import Contact from '@/components/home/Contact.astro';

import heroImage from "@/assets/heroImage.png";

const content = {
    textDecor: "HABLA CON NOSOTROS",
    title: "Asesoria que inspira",
    titleDecor: "Confianza",
    description: "En GNP Huehuetoca no vendemos polizas; diseñamos legados. Descubre una consultoria humana enfocada en proteger lo que más amas con estrategias a tu medida",
    textButton: "Hablar con un Experto",
    iconText: {
        title: "Proteccion total",
        subtitle: "100% seguro"
    }
}

---

<Layout title="GNP | Huehuetoca" description="Protegemos tu futuro con seguros confiables y asesoría profesional para ti y tu familia.">
	<Hero image={heroImage} content={content}/>
	<Services/>
	<Team/>
	<Faq/>
	<Contact/>
</Layout>
