---
---

<section class="w-full flex justify-center px-6 py-16 bg-white">
  <div class="max-w-6xl w-full flex flex-col gap-y-12">

    <!-- Header -->
    <div class="text-center">
      <h3 class="md:text-3xl text-2xl font-semibold">
        Nuestros Expertos
      </h3>
      <p class="opacity-60 mt-2 text-sm">
        Personas reales diseñando soluciones reales.
      </p>
    </div>

    <!-- Grid principal optimizado para desktop -->
    <div
      class="grid grid-cols-1 md:grid-cols-[1.1fr_1fr_1fr] md:grid-rows-[auto_auto] gap-8 lg:gap-12 items-stretch"
    >

      <!-- Imagen principal -->
      <div
        class="md:row-span-2 rounded-3xl overflow-hidden shadow-xl h-105 md:h-full"
      >
        <img
          src="https://images.pexels.com/photos/8266925/pexels-photo-8266925.jpeg"
          alt="Equipo profesional"
          class="w-full h-full object-cover"
        />
      </div>

      <!-- Card experto 1 -->
      <div
        class="relative rounded-3xl overflow-hidden shadow-lg group h-65 bg-slate-900 hover:-translate-y-1 transition-all duration-300"
      >
        <img
          src="https://images.pexels.com/photos/3184465/pexels-photo-3184465.jpeg"
          alt="Leonardo Kazuya"
          class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:scale-105 transition duration-500"
        />

        <div
          class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent"
        ></div>

        <div class="absolute bottom-4 left-4 text-white">
          <h3 class="font-semibold text-base">Leonardo Kazuya</h3>
          <p class="text-sm opacity-90">Especialista en seguros</p>
        </div>
      </div>

      <!-- Card experto 2 -->
      <div
        class="relative rounded-3xl overflow-hidden shadow-lg group h-65 bg-slate-900 hover:-translate-y-1 transition-all duration-300"
      >
        <img
          src="https://images.pexels.com/photos/3182764/pexels-photo-3182764.jpeg"
          alt="Jair Velarde"
          class="absolute inset-0 w-full h-full object-cover opacity-90 group-hover:scale-105 transition duration-500"
        />

        <div
          class="absolute inset-0 bg-linear-to-t from-black/70 to-transparent"
        ></div>

        <div class="absolute bottom-4 left-4 text-white">
          <h3 class="font-semibold text-base">Jair Velarde</h3>
          <p class="text-sm opacity-90">Especialista en seguros</p>
        </div>
      </div>

      <!-- Banner inferior alineado solo con expertos -->
      <div
        class="md:col-start-2 md:col-span-2 rounded-3xl bg-slate-100 py-12 px-10 flex flex-col items-center justify-center gap-y-6 text-center shadow-inner"
      >
        <h3
          class="text-[#ff6600] text-sm font-semibold tracking-wide uppercase"
        >
          Por qué nosotros
        </h3>

        <p
          class="md:text-3xl text-xl font-semibold leading-tight max-w-2xl"
        >
          Más de 500 familias protegidas
          con una visión humana.
        </p>

        <a
          href="#"
          class="border-b-2 border-[#ff6600] text-sm font-medium hover:opacity-70 transition"
        >
          Ver nuestra trayectoria
        </a>
      </div>

    </div>

  </div>
</section>