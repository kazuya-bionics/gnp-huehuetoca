---

import { Icon } from 'astro-icon/components';

const phone = "5217205274302"; // prefijo 521 para móviles en México
const message = encodeURIComponent(
  "Hola, me gustaría recibir información sobre sus planes de seguro."
);

const waLink = `https://wa.me/${phone}?text=${message}`;

---

<section class="grid grid-cols-1 md:grid-cols-2 bg-slate-200 px-8 py-16 gap-12">

    <!-- Gastos Médicos -->
    <div class="p-8 bg-white shadow-xl rounded-3xl flex flex-col gap-y-8">
        <div class="bg-slate-200 w-10 h-10 flex items-center justify-center rounded-md text-blue-800">
            <Icon name="material-symbols:medical-information-rounded" size={28} />
        </div>

        <div>  
            <h3 class="text-2xl font-semibold">
                Gastos Medicos
            </h3>
            <p class="text-sm mt-3">
                Acceso a la red hospitalaria mas prestigiosa, Soluciones de 
                salud integrales diseñadas para proteger su bienestar y el de
                sus seres queridos sin compromisos
            </p>
        </div>

        <a 
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="w-fit text-sm text-[#ff6600] flex items-center gap-x-2 font-medium hover:underline"
        >
            Solicitar Detalles 
            <span>
                <Icon name="material-symbols:arrow-forward" size={18} />
            </span>
        </a>
    </div>

    <!-- Plan de Ahorro -->
    <div class="p-8 bg-white shadow-xl rounded-3xl flex flex-col gap-y-8">
        <div class="bg-slate-200 w-10 h-10 flex items-center justify-center rounded-md text-blue-800">
            <Icon name="material-symbols:savings" size={28} />
        </div>

        <div>  
            <h3 class="text-2xl font-semibold">
                Plan de ahorro
            </h3>
            <p class="text-sm mt-3">
                Acceso a la red hospitalaria mas prestigiosa, Soluciones de 
                salud integrales diseñadas para proteger su bienestar y el de
                sus seres queridos sin compromisos
            </p>
        </div>

        <a 
            href={waLink}
            target="_blank"
            rel="noopener noreferrer"
            class="w-fit text-sm text-[#ff6600] flex items-center gap-x-2 font-medium hover:underline"
        >
            Explorar Planes 
            <span>
                <Icon name="material-symbols:arrow-forward" size={18} />
            </span>
        </a>
    </div>

</section>