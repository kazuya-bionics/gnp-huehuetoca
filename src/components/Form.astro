---
// ContactForm.astro — GNP Huehuetoca
// Web3Forms → leonardo.acosta@gnp.com.mx
// Tel: +52 720 527 4302
---

<section class="contact-section  px-8">
  <!-- Orbes de luz de fondo -->
  <div class="orb orb-1"></div>
  <div class="orb orb-2"></div>
  <div class="orb orb-3"></div>

  <div class="contact-wrapper">

    <!-- Columna izquierda: info -->
    <div class="contact-info">
      <span class="badge">● Contáctanos</span>
      <h2 class="info-title">
        Hablemos sobre<br />
        tu <em>tranquilidad</em>
      </h2>
      <p class="info-body">
        En GNP Huehuetoca diseñamos estrategias a tu medida.
        Déjanos tus datos y un experto te contactará pronto.
      </p>

      <div class="contact-links">
        <a href="tel:+527205274302" class="contact-link">
          <span class="link-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.29 6.29l1.17-1.17a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </span>
          <div>
            <span class="link-label">Teléfono directo</span>
            <span class="link-value">+52 720 527 4302</span>
          </div>
        </a>

        <a href="mailto:leonardo.acosta@gnp.com.mx" class="contact-link">
          <span class="link-icon">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </span>
          <div>
            <span class="link-label">Correo</span>
            <span class="link-value">leonardo.acosta@gnp.com.mx</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Columna derecha: form -->
    <div class="form-card">
      <form
        id="contact-form"
        action="https://api.web3forms.com/submit"
        method="POST"
        novalidate
      >
        <!-- Web3Forms config -->
        <input type="hidden" name="access_key" value="a1d84ae9-2fbf-4521-bac0-1d48c2206293" />
        <input type="hidden" name="to" value="leonardo.acosta@gnp.com.mx" />
        <input type="hidden" name="subject" value="Nuevo contacto desde GNP Huehuetoca" />
        <input type="hidden" name="from_name" value="Sitio Web GNP Huehuetoca" />
        <input type="checkbox" name="botcheck" style="display:none" />

        <div class="field">
          <label class="field-label" for="name">Nombre completo</label>
          <input
            id="name"
            type="text"
            name="name"
            placeholder="¿Cómo te llamas?"
            required
            autocomplete="name"
            class="field-input"
          />
        </div>

        <div class="field-row">
          <div class="field">
            <label class="field-label" for="email">Correo</label>
            <input
              id="email"
              type="email"
              name="email"
              placeholder="tu@correo.com"
              required
              autocomplete="email"
              class="field-input"
            />
          </div>
          <div class="field">
            <label class="field-label" for="phone">Teléfono</label>
            <input
              id="phone"
              type="tel"
              name="phone"
              placeholder="55 1234 5678"
              autocomplete="tel"
              class="field-input"
            />
          </div>
        </div>

        <div class="field">
          <label class="field-label" for="message">Mensaje</label>
          <textarea
            id="message"
            name="message"
            placeholder="Cuéntanos en qué te podemos ayudar..."
            rows="4"
            required
            class="field-input"
          ></textarea>
        </div>

        <button type="submit" class="submit-btn" id="submit-btn">
          <span class="btn-text">Hablar con un Experto</span>
          <span class="btn-arrow">→</span>
        </button>

        <!-- Estados de respuesta -->
        <div id="form-success" class="form-message form-success" aria-live="polite">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
          ¡Mensaje enviado! Te contactaremos pronto.
        </div>
        <div id="form-error" class="form-message form-error" aria-live="polite">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
          Algo salió mal. Intenta de nuevo.
        </div>
      </form>
    </div>

  </div>
</section>

<style>
  /* ── Fuentes ── */
  @import url('https://fonts.googleapis.com/css2?family=Fraunces:ital,wght@0,400;0,500;1,400;1,500&family=DM+Sans:wght@400;500&display=swap');

  /* ── Variables ── */
  :root {
    --orange: #f97316;
    --orange-dark: #ea6c0a;
    --orange-glow: rgba(249, 115, 22, 0.12);
    --text-primary: #111827;
    --text-muted: #6b7280;
    --text-faint: #9ca3af;
    --glass-bg: rgba(255, 255, 255, 0.52);
    --glass-border: rgba(255, 255, 255, 0.82);
    --input-bg: rgba(255, 255, 255, 0.65);
    --input-border: rgba(0, 0, 0, 0.08);
    --radius-form: 24px;
    --radius-input: 12px;
    --radius-btn: 14px;
    --shadow-form: 0 8px 40px rgba(0, 0, 0, 0.07), 0 1px 2px rgba(0,0,0,0.04), inset 0 1px 0 rgba(255,255,255,0.95);
  }

  /* ── Sección ── */
  .contact-section {
    font-family: 'DM Sans', sans-serif;
    width: 100%;
    min-height: 100svh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 2.25rem;
    position: relative;
    overflow: hidden;
    background: linear-gradient(145deg, #f5f7fa 0%, #edf1f7 45%, #e2eaf4 100%);
    box-sizing: border-box;
  }

  /* ── Orbes decorativos ── */
  .orb {
    position: absolute;
    border-radius: 50%;
    pointer-events: none;
    filter: blur(48px);
  }
  .orb-1 {
    width: 420px; height: 420px;
    top: -120px; right: -100px;
    background: radial-gradient(circle, rgba(249,115,22,0.09) 0%, transparent 70%);
  }
  .orb-2 {
    width: 500px; height: 500px;
    bottom: -160px; left: -140px;
    background: radial-gradient(circle, rgba(147,197,253,0.22) 0%, transparent 70%);
  }
  .orb-3 {
    width: 260px; height: 260px;
    top: 40%; left: 38%;
    background: radial-gradient(circle, rgba(249,115,22,0.05) 0%, transparent 70%);
  }

  /* ── Wrapper de dos columnas ── */
  .contact-wrapper {
    width: 100%;
    max-width: 900px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    position: relative;
    z-index: 1;
  }

  /* ── Columna info ── */
  .contact-info {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .badge {
    display: inline-block;
    font-size: 11px;
    font-weight: 500;
    color: var(--orange);
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .info-title {
    font-size: clamp(2rem, 5vw, 2.75rem);
    font-weight: 500;
    line-height: 1.2;
    color: var(--text-primary);
    margin: 0;
  }
  .info-title em {
    font-style: italic;
    color: var(--orange);
  }

  .info-body {
    font-size: 15px;
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0;
    max-width: 36ch;
  }

  .contact-links {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-top: 0.5rem;
  }

  .contact-link {
    display: flex;
    align-items: center;
    gap: 12px;
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.5);
    border: 1px solid rgba(255, 255, 255, 0.8);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transition: background 0.2s, transform 0.15s;
  }
  .contact-link:hover {
    background: rgba(255, 255, 255, 0.75);
    transform: translateY(-1px);
  }
  .contact-link:active {
    transform: scale(0.98);
  }

  .link-icon {
    width: 36px;
    height: 36px;
    border-radius: 10px;
    background: var(--orange-glow);
    color: var(--orange);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .contact-link > div {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .link-label {
    font-size: 11px;
    color: var(--text-faint);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    font-weight: 500;
  }
  .link-value {
    font-size: 14px;
    color: var(--text-primary);
    font-weight: 500;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* ── Tarjeta del formulario ── */
  .form-card {
    background: var(--glass-bg);
    backdrop-filter: blur(32px);
    -webkit-backdrop-filter: blur(32px);
    border: 1px solid var(--glass-border);
    border-radius: var(--radius-form);
    padding: 2rem 1.75rem;
    box-shadow: var(--shadow-form);
  }

  form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* ── Campos ── */
  .field {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .field-row {
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }

  .field-label {
    font-size: 11px;
    font-weight: 500;
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .field-input {
    width: 100%;
    box-sizing: border-box;
    background: var(--input-bg);
    border: 1px solid var(--input-border);
    border-radius: var(--radius-input);
    padding: 12px 16px;
    font-size: 16px; /* evita zoom en iOS */
    font-family: 'DM Sans', sans-serif;
    color: var(--text-primary);
    outline: none;
    transition: border-color 0.2s, background 0.2s, box-shadow 0.2s;
    -webkit-appearance: none;
    appearance: none;
    caret-color: var(--orange);
    resize: none;
  }
  .field-input::placeholder {
    color: #c8cdd6;
  }
  .field-input:focus {
    background: rgba(255, 255, 255, 0.92);
    border-color: var(--orange);
    box-shadow: 0 0 0 3px rgba(249, 115, 22, 0.11);
  }

  /* ── Botón ── */
  .submit-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    min-height: 52px;
    padding: 14px 24px;
    background: var(--orange);
    border: none;
    border-radius: var(--radius-btn);
    font-family: 'DM Sans', sans-serif;
    font-size: 15px;
    font-weight: 500;
    color: #fff;
    cursor: pointer;
    letter-spacing: 0.02em;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    box-shadow: 0 4px 20px rgba(249, 115, 22, 0.3);
    margin-top: 4px;
  }
  .submit-btn:hover {
    background: var(--orange-dark);
    box-shadow: 0 6px 24px rgba(249, 115, 22, 0.4);
    transform: translateY(-1px);
  }
  .submit-btn:active {
    transform: scale(0.98);
  }
  .submit-btn:disabled {
    opacity: 0.65;
    cursor: not-allowed;
    transform: none;
  }

  .btn-arrow {
    transition: transform 0.2s;
    font-size: 17px;
  }
  .submit-btn:hover .btn-arrow {
    transform: translateX(3px);
  }

  /* ── Mensajes de estado ── */
  .form-message {
    display: none;
    align-items: center;
    gap: 8px;
    padding: 12px 16px;
    border-radius: 12px;
    font-size: 14px;
    font-weight: 500;
  }
  .form-message.visible {
    display: flex;
  }
  .form-success {
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.25);
    color: #15803d;
  }
  .form-error {
    background: rgba(239, 68, 68, 0.09);
    border: 1px solid rgba(239, 68, 68, 0.2);
    color: #b91c1c;
  }

  /* ── Responsive: tablet y desktop ── */
  @media (min-width: 700px) {
    .contact-section {
      padding: 4rem 2rem;
    }

    .field-row {
      grid-template-columns: 1fr 1fr;
    }

    .form-card {
      padding: 2.5rem 2.25rem;
    }
  }

  @media (min-width: 860px) {
    .contact-wrapper {
      grid-template-columns: 1fr 1.15fr;
      align-items: center;
      gap: 3rem;
    }

    .info-body {
      max-width: 30ch;
    }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    btn.disabled = true;
    btn.querySelector('.btn-text')!.textContent = 'Enviando...';
    successMsg.classList.remove('visible');
    errorMsg.classList.remove('visible');

    try {
      const data = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });
      const json = await res.json();

      if (json.success) {
        successMsg.classList.add('visible');
        form.reset();
      } else {
        errorMsg.classList.add('visible');
      }
    } catch {
      errorMsg.classList.add('visible');
    } finally {
      btn.disabled = false;
      btn.querySelector('.btn-text')!.textContent = 'Hablar con un Experto';
    }
  });
</script>