---
// ContactForm.astro — GNP Huehuetoca
// Web3Forms → leonardo.acosta@gnp.com.mx
// Tel: +52 720 527 4302
---

<section class="relative flex min-h-svh w-full items-center justify-center overflow-hidden bg-linear-to-br from-[#f5f7fa] via-[#edf1f7] to-[#e2eaf4] px-9 py-12 box-border">

  <!-- Orbes de luz de fondo -->
  <div class="pointer-events-none absolute -top-30 -right-25 h-105 w-105 rounded-full bg-[radial-gradient(circle,rgba(249,115,22,0.09)_0%,transparent_70%)] blur-[48px]"></div>
  <div class="pointer-events-none absolute -bottom-40 -left-35 h-125 w-125nded-full bg-[radial-gradient(circle,rgba(147,197,253,0.22)_0%,transparent_70%)] blur-[48px]"></div>
  <div class="pointer-events-none absolute top-[40%] left-[38%] h-65 w-65 rounded-full bg-[radial-gradient(circle,rgba(249,115,22,0.05)_0%,transparent_70%)] blur-[48px]"></div>

  <div class="relative z-10 grid w-full max-w-225 grid-cols-1 gap-8 md:grid-cols-[1fr_1.15fr] md:items-center md:gap-12">

    <!-- Columna izquierda: info -->
    <div class="flex flex-col gap-5">
      <span class="text-[11px] font-medium uppercase tracking-[0.08em] text-orange-500">● Contáctanos</span>

      <h2 class="m-0 text-[clamp(2rem,5vw,2.75rem)] font-medium leading-[1.2] text-gray-900">
        Hablemos sobre<br />
        tu <em class="italic text-orange-500">tranquilidad</em>
      </h2>

      <p class="m-0 max-w-[36ch] text-[15px] leading-[1.7] text-gray-500 md:max-w-[30ch]">
        En GNP Huehuetoca diseñamos estrategias a tu medida.
        Déjanos tus datos y un experto te contactará pronto.
      </p>

      <div class="mt-2 flex flex-col gap-3">
        <a href="tel:+527205274302"
           class="flex items-center gap-3 rounded-[14px] border border-white/80 bg-white/50 px-4 py-3 no-underline backdrop-blur-md transition-all duration-200 hover:-translate-y-px hover:bg-white/75 active:scale-[0.98]">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] bg-orange-500/10 text-orange-500">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.77 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 9.91a16 16 0 0 0 6.29 6.29l1.17-1.17a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </span>
          <div class="flex min-w-0 flex-col gap-px">
            <span class="text-[11px] font-medium uppercase tracking-[0.05em] text-gray-400">Teléfono directo</span>
            <span class="truncate text-sm font-medium text-gray-900">+52 720 527 4302</span>
          </div>
        </a>

        <a href="mailto:leonardo.acosta@gnp.com.mx"
           class="flex items-center gap-3 rounded-[14px] border border-white/80 bg-white/50 px-4 py-3 no-underline backdrop-blur-md transition-all duration-200 hover:-translate-y-px hover:bg-white/75 active:scale-[0.98]">
          <span class="flex h-9 w-9 shrink-0 items-center justify-center rounded-[10px] bg-orange-500/10 text-orange-500">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="20" height="16" x="2" y="4" rx="2"/>
              <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
            </svg>
          </span>
          <div class="flex min-w-0 flex-col gap-px">
            <span class="text-[11px] font-medium uppercase tracking-[0.05em] text-gray-400">Correo</span>
            <span class="truncate text-sm font-medium text-gray-900">leonardo.acosta@gnp.com.mx</span>
          </div>
        </a>
      </div>
    </div>

    <!-- Columna derecha: form -->
    <div class="rounded-3xl border border-white/80 bg-white/52 p-8 shadow-[0_8px_40px_rgba(0,0,0,0.07),0_1px_2px_rgba(0,0,0,0.04),inset_0_1px_0_rgba(255,255,255,0.95)] backdrop-blur-[32px] md:p-10">
      <form id="contact-form" novalidate>
        <!-- Web3Forms config -->
        <input type="hidden" name="access_key" value="a1d84ae9-2fbf-4521-bac0-1d48c2206293" />
        <input type="hidden" name="to" value="leonardo.acosta@gnp.com.mx" />
        <input type="hidden" name="subject" value="Nuevo contacto desde GNP Huehuetoca" />
        <input type="hidden" name="from_name" value="Sitio Web GNP Huehuetoca" />
        <input type="checkbox" name="botcheck" class="hidden" />

        <div class="flex flex-col gap-4">

          <!-- Nombre -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-medium uppercase tracking-[0.06em] text-gray-500" for="name">
              Nombre completo
            </label>
            <input
              id="name" type="text" name="name"
              placeholder="¿Cómo te llamas?"
              autocomplete="name"
              class="field-input w-full rounded-xl border border-black/8 bg-white/65 px-4 py-3 font-[DM_Sans] text-base text-gray-900 caret-orange-500 outline-none placeholder:text-[#c8cdd6] transition-all duration-200 focus:border-orange-500 focus:bg-white/92 focus:shadow-[0_0_0_3px_rgba(249,115,22,0.11)] appearance-none"
            />
            <span class="field-hint hidden text-[12px] text-red-700"></span>
          </div>

          <!-- Correo + Teléfono -->
          <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
            <div class="flex flex-col gap-1.5">
              <label class="text-[11px] font-medium uppercase tracking-[0.06em] text-gray-500" for="email">
                Correo
              </label>
              <input
                id="email" type="email" name="email"
                placeholder="tu@correo.com"
                autocomplete="email"
                class="field-input w-full rounded-xl border border-black/8 bg-white/65 px-4 py-3 font-[DM_Sans] text-base text-gray-900 caret-orange-500 outline-none placeholder:text-[#c8cdd6] transition-all duration-200 focus:border-orange-500 focus:bg-white/92 focus:shadow-[0_0_0_3px_rgba(249,115,22,0.11)] appearance-none"
              />
              <span class="field-hint hidden text-[12px] text-red-700"></span>
            </div>
            <div class="flex flex-col gap-1.5">
              <label class="text-[11px] font-medium uppercase tracking-[0.06em] text-gray-500" for="phone">
                Teléfono
              </label>
              <input
                id="phone" type="tel" name="phone"
                placeholder="55 1234 5678"
                autocomplete="tel"
                class="field-input w-full rounded-xl border border-black/8 bg-white/65 px-4 py-3 font-[DM_Sans] text-base text-gray-900 caret-orange-500 outline-none placeholder:text-[#c8cdd6] transition-all duration-200 focus:border-orange-500 focus:bg-white/92 focus:shadow-[0_0_0_3px_rgba(249,115,22,0.11)] appearance-none"
              />
              <span class="field-hint hidden text-[12px] text-red-700"></span>
            </div>
          </div>

          <!-- Mensaje -->
          <div class="flex flex-col gap-1.5">
            <label class="text-[11px] font-medium uppercase tracking-[0.06em] text-gray-500" for="message">
              Mensaje
            </label>
            <textarea
              id="message" name="message"
              placeholder="Cuéntanos en qué te podemos ayudar..."
              rows="4"
              class="field-input w-full resize-none rounded-xl border border-black/8 bg-white/65 px-4 py-3 font-[DM_Sans] text-base text-gray-900 caret-orange-500 outline-none placeholder:text-[#c8cdd6] transition-all duration-200 focus:border-orange-500 focus:bg-white/92 focus:shadow-[0_0_0_3px_rgba(249,115,22,0.11)] appearance-none"
            ></textarea>
            <span class="field-hint hidden text-[12px] text-red-700"></span>
          </div>

          <!-- Botón -->
          <button
            type="submit" id="submit-btn"
            class="mt-1 flex min-h-13 w-full cursor-pointer items-center justify-center gap-2.5 rounded-[14px] border-none bg-orange-500 px-6 py-3.5 font-[DM_Sans] text-[15px] font-medium tracking-[0.02em] text-white shadow-[0_4px_20px_rgba(249,115,22,0.3)] transition-all duration-200 hover:-translate-y-px hover:bg-[#ea6c0a] hover:shadow-[0_6px_24px_rgba(249,115,22,0.4)] active:scale-[0.98] disabled:cursor-not-allowed disabled:opacity-65 disabled:transform-none"
          >
            <span class="btn-text">Hablar con un Experto</span>
            <span class="btn-arrow text-[17px] transition-transform duration-200">→</span>
          </button>

          <!-- Estados de respuesta -->
          <div id="form-success" class="form-message hidden items-center gap-2 rounded-xl border border-green-500/25 bg-green-500/10 px-4 py-3 text-sm font-medium text-green-800" aria-live="polite">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
            ¡Mensaje enviado! Te contactaremos pronto.
          </div>
          <div id="form-error" class="form-message hidden items-center gap-2 rounded-xl border border-red-500/20 bg-red-500/9 px-4 py-3 text-sm font-medium text-red-700" aria-live="polite">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="8" y2="12"/><line x1="12" x2="12.01" y1="16" y2="16"/></svg>
            Algo salió mal. Intenta de nuevo.
          </div>

        </div>
      </form>
    </div>

  </div>
</section>

<script>
  const form       = document.getElementById('contact-form') as HTMLFormElement;
  const btn        = document.getElementById('submit-btn')   as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg   = document.getElementById('form-error')   as HTMLElement;

  const EMAIL_RE = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
  const PHONE_RE = /\d{8,}/;

  // ── Error visual por campo ────────────────────────────────────
  function setError(input: HTMLInputElement | HTMLTextAreaElement, msg: string | null) {
    const hint = input.parentElement!.querySelector('.field-hint') as HTMLElement;
    if (msg) {
      input.classList.add('!border-red-500', '!shadow-[0_0_0_3px_rgba(239,68,68,0.10)]');
      hint.textContent = msg;
      hint.classList.remove('hidden');
    } else {
      input.classList.remove('!border-red-500', '!shadow-[0_0_0_3px_rgba(239,68,68,0.10)]');
      hint.classList.add('hidden');
    }
  }

  // ── Validación completa ───────────────────────────────────────
  function validateForm(): boolean {
    const name    = form.elements.namedItem('name')    as HTMLInputElement;
    const email   = form.elements.namedItem('email')   as HTMLInputElement;
    const phone   = form.elements.namedItem('phone')   as HTMLInputElement;
    const message = form.elements.namedItem('message') as HTMLTextAreaElement;

    let valid = true;

    if (!name.value.trim()) {
      setError(name, 'Por favor ingresa tu nombre completo.'); valid = false;
    } else { setError(name, null); }

    if (!EMAIL_RE.test(email.value.trim())) {
      setError(email, 'Ingresa un correo electrónico válido.'); valid = false;
    } else { setError(email, null); }

    if (phone.value.trim() && !PHONE_RE.test(phone.value.replace(/\D/g, ''))) {
      setError(phone, 'El teléfono debe tener al menos 8 dígitos.'); valid = false;
    } else { setError(phone, null); }

    if (!message.value.trim()) {
      setError(message, 'Por favor escribe tu mensaje.'); valid = false;
    } else { setError(message, null); }

    return valid;
  }

  // ── Validación en tiempo real ────────────────────────────────
  ['name', 'email', 'phone', 'message'].forEach(name => {
    const el = form.elements.namedItem(name) as HTMLInputElement | HTMLTextAreaElement;
    el?.addEventListener('blur', () => validateForm());
    el?.addEventListener('input', () => {
      if (el.classList.contains('!border-red-500')) validateForm();
    });
  });

  // ── Envío ─────────────────────────────────────────────────────
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();

    if (!validateForm()) return;

    btn.disabled = true;
    btn.querySelector('.btn-text')!.textContent = 'Enviando...';
    successMsg.classList.add('hidden');
    errorMsg.classList.add('hidden');

    try {
      const res  = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: new FormData(form),
      });
      const json = await res.json();

      if (json.success) {
        successMsg.classList.remove('hidden');
        successMsg.classList.add('flex');
        form.reset();
      } else {
        errorMsg.classList.remove('hidden');
        errorMsg.classList.add('flex');
      }
    } catch {
      errorMsg.classList.remove('hidden');
      errorMsg.classList.add('flex');
    } finally {
      btn.disabled = false;
      btn.querySelector('.btn-text')!.textContent = 'Hablar con un Experto';
    }
  });
</script>